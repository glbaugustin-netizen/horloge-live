# Firebase Authentication
# Copier ce fichier en .env.local et remplir les valeurs
# Ne jamais committer .env.local sur GitHub

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# App Check — protection anti-bots / anti-DDoS (optionnel mais recommandé)
# Clé "site" reCAPTCHA v3 à créer dans Firebase Console > App Check.
# Laisser vide tant que App Check n'est pas configuré (le code est no-op sans clé).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

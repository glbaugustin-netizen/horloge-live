rules_version = '2';

// Règles de sécurité Firestore — horloge-live.com
// À déployer via : firebase deploy --only firestore:rules
//
// Modèle : chaque utilisateur ne peut lire/écrire QUE ses propres données
// sous /users/{uid}/**. Tout le reste est refusé par défaut.

service cloud.firestore {
  match /databases/{database}/documents {

    // Données d'un utilisateur : préférences (/preferences/main)
    // et consentement RGPD (/data/consent).
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }

    // Refus explicite de tout le reste (defense in depth).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
